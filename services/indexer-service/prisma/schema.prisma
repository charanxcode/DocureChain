generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BlockchainEvent {
  id          String   @id @default(cuid())
  txHash      String   @unique
  blockNumber Int
  eventName   String
  payload     Json
  processedAt DateTime @default(now())
}
