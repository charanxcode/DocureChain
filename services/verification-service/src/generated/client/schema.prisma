generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Document {
  id        String    @id @default(cuid())
  ownerId   String
  title     String
  docType   String
  fileHash  String    @unique
  ipfsCID   String?
  s3Key     String?
  txHash    String?
  status    String
  issuerId  String?
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}
